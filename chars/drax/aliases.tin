#alias {mycorpsetrig-donates} {

    #NOP -- juggernaut;
    #if {"$guild" == "juggernaut"} {
        #echo {<ffa>donates argument passed - setting up donates corpsetrig for guild: <fff>$guild!!<088>};
        corpsetrig-clear;
        corpsetrig+ wrap;
        corpsetrig+ fdeener2;
