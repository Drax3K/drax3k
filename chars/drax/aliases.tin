#NOP -- turn gags on;
#alias {gagson} {
    #if {"$guild" == "juggernaut"} {
        gag+ hpbar
    };
    #elseif {"$guild" == "mage"} {
        gag+ hpbar;
        #gag {  --> %*};
        #gag {%*-hp-}
    };
    #elseif {"$guild" == "elemental"} {
        gag+ hpbar
    };
    #elseif {"$guild" == "bard"} {
        #nop;
    };
    #elseif {"$guild" == "fremen"} {
        gag+ hpbar
    };
    #elseif {"$guild" == "monk"} {
        #nop;
    };
    #elseif {"$guild" == "necromancer"} {
        #nop;
    };
    #else {
        #NOP;
    }
};
#NOP -- Recovery commands (suspend, meditation, rest etc);

#alias {m} {
    #if {"$guild" == "mage"} {
        #if {"%0" == ""} {
            study spellbook;
        };
    };
    #elseif {"$guild" == "fremen"} {
        #if {"%0" == ""} {
            suspend;
        };
    };
    #elseif {"$guild" == "monk"} {
        meditate;
    };
};

#NOP Setup 3kreport

#alias {set3kreport} {
    3kReport-clear;
    3kReport+ killer;
    3kReport+ rounds;
    3kReport+ class;
    3kReport+ xp;
    3kReport+ xp_ratio;
    3kReport+ coins;
    3kReport+ dmg_dealt;
    3kReport+ dmg_received;
};

#alias {3kr} {
    3kReport
};

